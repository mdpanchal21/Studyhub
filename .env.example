# Server
PORT=5000
NODE_ENV=development

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/study-platform

# Redis (local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (create at github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Gemini AI (get from aistudio.google.com)
GEMINI_API_KEY=

# Resend (for emails, sign up at resend.com)
RESEND_API_KEY=

# Gmail SMTP (backup for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Server URL (used for OAuth callback URLs)
SERVER_URL=http://localhost:5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
