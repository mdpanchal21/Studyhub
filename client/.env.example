# ─── Client Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env to git — only commit .env.example
#
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of the backend API server (no trailing slash)
# Dev example  : http://localhost:5000
# Network dev  : http://172.16.16.108:5000
# Production   : https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Optional: override the port Vite dev server runs on (default: 5173)
# VITE_PORT=5173
